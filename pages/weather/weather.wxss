/* 2列网格布局 */
.grid-2 {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  padding: 15rpx 0;
  box-sizing: border-box;
}

.detail-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.detail-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 逐时预报横向滚动 */
.hourly-scroll {
  display: flex;
  padding: 10rpx 0;
}

.hourly-item {
  flex-shrink: 0;
  width: 140rpx;
  text-align: center;
  padding: 15rpx 10rpx;
  border-right: 1rpx solid #eee;
}

.hourly-item:last-child {
  border-right: none;
}

.hourly-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.hourly-temp {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.hourly-desc {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hourly-rain {
  font-size: 20rpx;
  color: #4CAF50;
}

/* 加载提示遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-content {
  text-align: center;
  padding: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}