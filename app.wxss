/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn {
  background-color: #4CAF50;
  color: white;
  padding: 20rpx;
  border-radius: 8rpx;
  text-align: center;
  margin: 10rpx 0;
  font-size: 32rpx;
}

.btn-primary {
  background-color: #4CAF50;
}

.btn-secondary {
  background-color: #666;
}

.btn-danger {
  background-color: #f44336;
}

.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 10rpx 0;
  font-size: 32rpx;
}

.select {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 10rpx 0;
  font-size: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.text-center {
  text-align: center;
}

.text-red {
  color: #f44336;
}

.text-green {
  color: #4CAF50;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}